{
  "headers": [
    {
      "source": "/app/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/econ-calendar",
      "destination": "https://nfs.faireconomy.media/ff_calendar_thisweek.json"
    }
  ]
}
